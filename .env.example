# Copy this file to .env and fill in the values locally.
# Never commit .env.

# Required for proposal generation.
ANTHROPIC_API_KEY=

# Required only when driftguard.config.json uses provider: "openai".
OPENAI_API_KEY=

# Required only when driftguard.config.json uses provider: "groq".
GROQ_API_KEY=

# Required for creating GitHub PRs unless `gh auth login` is already configured.
# Prefer a fine-grained token with repo/pull-request permissions for the test repo.
GH_TOKEN=

# Alternative to GH_TOKEN. driftguard checks GITHUB_TOKEN first.
GITHUB_TOKEN=
